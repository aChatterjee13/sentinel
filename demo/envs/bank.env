# Playbook A — UK regulated bank credit decisioning demo
# Source this before running scripts/bank_demo.sh
#   source demo/envs/bank.env

export SENTINEL_DEMO_PLAYBOOK=bank
export SENTINEL_CONFIG_PATH=./demo/configs/credit_decisioning.yaml
export SENTINEL_AUDIT_PATH=./demo/audit/bank/

# Notification webhooks — leave blank for the demo (channels run in disabled mode)
export SLACK_WEBHOOK_URL=
export TEAMS_WEBHOOK_URL=
export PD_ROUTING_KEY=

# Optional Azure ML hooks — leave blank for offline demo
export AZURE_SUBSCRIPTION_ID=
export AZURE_RESOURCE_GROUP=
export AZURE_ML_WORKSPACE=

export SENTINEL_LOG_LEVEL=INFO
