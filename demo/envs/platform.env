# OpenTelemetry endpoint — for trace export demo
export OTLP_ENDPOINT=http://localhost:4318/v1/traces

# LLM providers
export OPENAI_API_KEY=
export AZURE_OPENAI_ENDPOINT=
export SENTINEL_LLM_MODE=mock

export SENTINEL_LOG_LEVEL=INFO
