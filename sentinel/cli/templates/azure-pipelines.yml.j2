# Azure DevOps pipeline for Sentinel-monitored model: {{ model_name }}
# Generated by `sentinel init --ci azure-devops`

trigger:
  branches:
    include:
      - main
  paths:
    include:
      - sentinel.yaml
      - "*.py"

schedules:
  - cron: "0 6 * * *"
    displayName: "Daily drift check"
    branches:
      include:
        - main
    always: true

pool:
  vmImage: "ubuntu-latest"

variables:
  pythonVersion: "3.11"
  sentinelConfig: "sentinel.yaml"

stages:
  - stage: Validate
    displayName: "Lint & Test"
    jobs:
      - job: LintTest
        displayName: "Lint, type-check, and unit test"
        steps:
          - task: UsePythonVersion@0
            inputs:
              versionSpec: "$(pythonVersion)"
            displayName: "Use Python $(pythonVersion)"

          - script: |
              python -m pip install --upgrade pip
              pip install -e ".[all,dev]"
            displayName: "Install dependencies"

          - script: |
              ruff check sentinel/
              ruff format --check sentinel/
            displayName: "Lint (ruff)"

          - script: |
              mypy sentinel/ --strict
            displayName: "Type check (mypy)"

          - script: |
              pytest tests/unit/ -v --cov=sentinel --cov-report=xml
            displayName: "Unit tests"

          - task: PublishTestResults@2
            inputs:
              testResultsFormat: "JUnit"
              testResultsFiles: "**/junit.xml"
            condition: always()
            displayName: "Publish test results"

          - task: PublishCodeCoverageResults@1
            inputs:
              codeCoverageTool: "Cobertura"
              summaryFileLocation: "coverage.xml"
            condition: always()
            displayName: "Publish coverage"

  - stage: DriftCheck
    displayName: "Drift Detection"
    dependsOn: Validate
    jobs:
      - job: CheckDrift
        displayName: "Run sentinel drift check"
        steps:
          - task: UsePythonVersion@0
            inputs:
              versionSpec: "$(pythonVersion)"
            displayName: "Use Python $(pythonVersion)"

          - script: |
              python -m pip install --upgrade pip
              pip install -e ".[all]"
            displayName: "Install dependencies"

          - script: |
              sentinel config validate --config $(sentinelConfig)
            displayName: "Validate config"

          - script: |
              sentinel check --config $(sentinelConfig)
            displayName: "Run drift detection"

  - stage: Deploy
    displayName: "Deploy Model"
    dependsOn: DriftCheck
    condition: and(succeeded(), eq(variables['Build.SourceBranch'], 'refs/heads/main'))
    jobs:
      - deployment: DeployModel
        displayName: "Deploy with approval gate"
        environment: "production"
        strategy:
          runOnce:
            deploy:
              steps:
                - task: UsePythonVersion@0
                  inputs:
                    versionSpec: "$(pythonVersion)"
                  displayName: "Use Python $(pythonVersion)"

                - script: |
                    python -m pip install --upgrade pip
                    pip install -e ".[all]"
                  displayName: "Install dependencies"

                - script: |
                    sentinel status --config $(sentinelConfig)
                  displayName: "Pre-deploy status"

                - script: |
                    sentinel deploy --config $(sentinelConfig) --version $(Build.BuildNumber) --strategy canary --traffic 5
                  displayName: "Deploy (canary 5%)"
