# Playbook E — Enterprise agent platform demo
# Source this before running scripts/platform_demo.sh

export SENTINEL_DEMO_PLAYBOOK=platform
export SENTINEL_CONFIG_PATH=./demo/configs/multi_team_agents.yaml
export SENTINEL_AUDIT_PATH=./demo/audit/platform/

export SLACK_WEBHOOK_URL=
export TEAMS_WEBHOOK_URL=
