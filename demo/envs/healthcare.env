# Playbook C — Healthcare clinical decision support agent demo
# Source this before running scripts/healthcare_demo.sh

export SENTINEL_DEMO_PLAYBOOK=healthcare
export SENTINEL_CONFIG_PATH=./demo/configs/clinical_decision.yaml
export SENTINEL_AUDIT_PATH=./demo/audit/healthcare/

export SLACK_WEBHOOK_URL=
export PD_ROUTING_KEY=

# LLM provider — leave blank for offline mock mode
export OPENAI_API_KEY=
export AZURE_OPENAI_ENDPOINT=
export AZURE_OPENAI_KEY=
export SENTINEL_LLM_MODE=mock

# HIPAA note: never source a .env file with real PHI keys on a demo laptop
export SENTINEL_LOG_LEVEL=INFO
